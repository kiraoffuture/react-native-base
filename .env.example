# Copy to .env.develop, .env.staging, or .env.product.
# Run with: yarn start:develop | start:staging | start:product
# Or build: yarn ios:develop | ios:staging | ios:product

APP_ENV=develop # develop, staging, product
APP_NAME=react-native-base
APP_ID=com.example.app
SERVER_URL=https://dev-api.example.com
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Sentry (optional)
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=xxx
