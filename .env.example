# Sentry: Get DSN from Sentry Dashboard > Project Settings > Client Keys (DSN).
# Required to send errors/crashes to Sentry.
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# (Optional) Upload source maps on build: create an Auth Token at
# Sentry > Settings > Auth Tokens. Do not commit the token.
SENTRY_AUTH_TOKEN=xxx
